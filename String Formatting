def print_formatted(number):
    # Calculate the width based on the binary representation of the maximum number
    width = len(bin(number)[2:])
    
    for i in range(1, number + 1):
        # Generate the formatted strings for each base
        # d = decimal, o = octal, X = capitalized hex, b = binary
        decimal = str(i).rjust(width)
        octal = oct(i)[2:].rjust(width)
        hexadecimal = hex(i)[2:].upper().rjust(width)
        binary = bin(i)[2:].rjust(width)
        
        # Print all values separated by a single space
        print(f"{decimal} {octal} {hexadecimal} {binary}")

