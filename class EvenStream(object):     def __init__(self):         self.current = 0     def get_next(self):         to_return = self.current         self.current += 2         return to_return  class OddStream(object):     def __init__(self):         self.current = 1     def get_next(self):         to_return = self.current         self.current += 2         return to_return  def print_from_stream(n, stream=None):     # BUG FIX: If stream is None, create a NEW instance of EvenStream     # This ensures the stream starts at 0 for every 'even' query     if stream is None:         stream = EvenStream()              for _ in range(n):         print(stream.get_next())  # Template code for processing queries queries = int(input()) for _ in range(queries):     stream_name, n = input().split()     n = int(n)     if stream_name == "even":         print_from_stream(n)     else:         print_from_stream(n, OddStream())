def is_vowel(letter):
    # Bug fix: Ensure 'y' is included as a vowel per the rules
    return letter in ['a', 'e', 'i', 'o', 'u', 'y']

def score_words(words):
    score = 0
    for word in words:
        num_vowels = 0
        for letter in word:
            if is_vowel(letter):
                num_vowels += 1
        
        # Bug fix: If the count is even, add 2. Otherwise, add 1.
        if num_vowels % 2 == 0:
            score += 2
        else:
            score += 1
    return score

# Process Input
n = int(input())
words = input().split()
print(score_words(words))
