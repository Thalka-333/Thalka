def is_leap(year):
    leap = False
    
    # Condition 1: Check if divisible by 4
    if year % 4 == 0:
        # Condition 2: If divisible by 100, it's NOT a leap year...
        if year % 100 == 0:
            # Condition 3: ...unless it is also divisible by 400
            if year % 400 == 0:
                leap = True
            else:
                leap = False
        else:
            # Divisible by 4 but not 100
            leap = True
    else:
        # Not divisible by 4
        leap = False
        
    return leap

