from itertools import combinations

# Read input and split into string S and integer k
s, k = input().split()
s = sorted(s)  # Sort string to ensure lexicographical order

# Loop through each size from 1 up to k
for i in range(1, int(k) + 1):
    # Generate combinations of current size i
    for combo in combinations(s, i):
        print("".join(combo))
