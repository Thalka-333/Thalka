import numpy

# Crucial step for the HackerRank checker to handle spacing/alignment
numpy.set_printoptions(legacy='1.13')

# Step 1: Read the input and convert it to a float array
# input().split() gets the string list, map converts to float
a = numpy.array(input().split(), float)

# Step 2: Print Floor
# Largest integer <= x
print(numpy.floor(a))

# Step 3: Print Ceil
# Smallest integer >= x
print(numpy.ceil(a))

# Step 4: Print Rint
# Rounds to the nearest integer
print(numpy.rint(a))
