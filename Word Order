from collections import OrderedDict

# Read the number of words
n = int(input())

# Use OrderedDict to keep track of word counts and order of appearance
word_counts = OrderedDict()

for _ in range(n):
    word = input().strip()
    if word in word_counts:
        word_counts[word] += 1
    else:
        word_counts[word] = 1

# Output 1: The number of distinct words
print(len(word_counts))

# Output 2: The occurrences of each word in order of appearance
print(*(word_counts.values()))
