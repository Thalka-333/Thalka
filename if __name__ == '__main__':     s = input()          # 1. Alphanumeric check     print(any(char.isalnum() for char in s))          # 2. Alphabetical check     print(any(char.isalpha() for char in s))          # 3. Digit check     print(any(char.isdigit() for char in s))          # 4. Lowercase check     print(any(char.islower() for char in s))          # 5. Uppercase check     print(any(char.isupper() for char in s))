def count_substring(string, sub_string):
    count = 0
    # Iterate through the main string up to the point where 
    # the remaining length is at least the length of the substring
    for i in range(len(string) - len(sub_string) + 1):
        # Check if the slice starting at index 'i' matches the sub_string
        if string[i : i + len(sub_string)] == sub_string:
            count += 1
    return count


