import re

def fun(s):
    # Regex breakdown:
    # ^[a-zA-Z0-9_-]+   : Username (letters, digits, -, _)
    # @[a-zA-Z0-9]+     : Website (letters, digits)
    # \.[a-zA-Z]{1,3}$  : Extension (letters only, max length 3)
    pattern = r'^[a-zA-Z0-9_-]+@[a-zA-Z0-9]+\.[a-zA-Z]{1,3}$'
    return re.match(pattern, s)
