
import numpy

def arrays(arr):
    # arr is a list of strings from the input
    # 1. Reverse the list using [::-1]
    # 2. Convert to a numpy array with float type
    return numpy.array(arr[::-1], float)

# Read the space-separated string and split into a list
line = input().strip().split(' ')

# Call the function and print the result
result = arrays(line)
print(result)

