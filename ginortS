def custom_sort(c):
    if c.islower():
        # Lowercase: priority 0, then sort by character value
        return (0, c)
    elif c.isupper():
        # Uppercase: priority 1, then sort by character value
        return (1, c)
    elif c.isdigit():
        if int(c) % 2 != 0:
            # Odd digits: priority 2, then sort by digit value
            return (2, c)
        else:
            # Even digits: priority 3, then sort by digit value
            return (3, c)

# Read input string
s = input()

# Sort using the custom key and join back into a string
print("".join(sorted(s, key=custom_sort)))
