from datetime import datetime

# The format matches: Day dd Mon yyyy hh:mm:ss +xxxx
fmt = '%a %d %b %Y %H:%M:%S %z'

for _ in range(int(input())):
    t1 = datetime.strptime(input(), fmt)
    t2 = datetime.strptime(input(), fmt)
    
    # Subtracting two timezone-aware datetimes gives a timedelta object
    diff = abs(int((t1 - t2).total_seconds()))
    print(diff)

