import re

def is_valid_card(card):
    # Rule 1: Check basic structure (starts with 4,5,6 and has correct separators/digits)
    # Allows 16 digits OR 4 groups of 4 separated by hyphens
    if not re.match(r'^[456]\d{3}(-?\d{4}){3}$', card):
        return False
    
    # Rule 2: Remove hyphens to check the clean number
    clean_card = card.replace("-", "")
    
    # Rule 3: Check for 4 or more consecutive repeated digits
    # (\d) matches a digit, \1{3,} checks if it repeats 3+ more times (total 4+)
    if re.search(r'(\d)\1{3,}', clean_card):
        return False
        
    return True

# Read number of test cases
n = int(input())

for _ in range(n):
    card_number = input().strip()
    if is_valid_card(card_number):
        print("Valid")
    else:
        print("Invalid")
