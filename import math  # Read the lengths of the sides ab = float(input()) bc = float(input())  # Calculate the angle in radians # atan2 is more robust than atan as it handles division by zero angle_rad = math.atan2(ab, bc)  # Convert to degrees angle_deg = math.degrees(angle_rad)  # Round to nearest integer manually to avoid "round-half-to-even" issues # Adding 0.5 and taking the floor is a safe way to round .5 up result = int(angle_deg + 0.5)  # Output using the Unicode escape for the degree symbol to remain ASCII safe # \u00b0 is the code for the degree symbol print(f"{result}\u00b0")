import math

# Read lengths of sides AB and BC
ab = int(input())
bc = int(input())

# Calculate the angle in radians using arctan(opposite/adjacent)
# Angle BCA = arctan(AB/BC)
angle_rad = math.atan2(ab, bc)

# Convert radians to degrees
angle_deg = math.degrees(angle_rad)

# Round to the nearest integer and add the degree symbol
# Using round() and then int() to ensure 56.5 becomes 57
print(str(int(round(angle_deg))) + '°')
