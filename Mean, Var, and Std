import numpy

# 1. Read N and M
n, m = map(int, input().split())

# 2. Read the array elements and convert to a NumPy array
# We use float to ensure standard deviation calculations match the expected precision
data = [list(map(int, input().split())) for _ in range(n)]
my_array = numpy.array(data)

# 3. Calculate and print outputs
# Mean along axis 1
print(numpy.mean(my_array, axis=1))

# Var along axis 0
print(numpy.var(my_array, axis=0))

# Std along axis None
# We use numpy.around or simple float printing if the legacy mode was the only issue
result_std = numpy.std(my_array)

# To match HackerRank's "1.11803398875" exactly without legacy formatting issues:
print(numpy.around(result_std, 11) if result_std != 0.0 else 0.0)
