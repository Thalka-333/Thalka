import re

def is_valid_uid(uid):
    # Rule 1: Must be exactly 10 characters
    if len(uid) != 10:
        return False
    
    # Rule 2: Only alphanumeric characters
    if not uid.isalnum():
        return False
    
    # Rule 3: No character should repeat
    if len(set(uid)) != 10:
        return False
    
    # Rule 4: At least 2 uppercase characters
    if len(re.findall(r'[A-Z]', uid)) < 2:
        return False
    
    # Rule 5: At least 3 digits
    if len(re.findall(r'[0-9]', uid)) < 3:
        return False
    
    return True

# Read number of test cases
t = int(input())

for _ in range(t):
    uid = input().strip()
    if is_valid_uid(uid):
        print("Valid")
    else:
        print("Invalid")
