from itertools import combinations

# Read input
n = int(input())
letters = input().split()
k = int(input())

# Generate all possible index combinations of size k
combos = list(combinations(range(n), k))

# Count combinations that include indices pointing to 'a'
favorable = 0
for c in combos:
    if any(letters[i] == 'a' for i in c):
        favorable += 1

# Calculate and print probability
print(f"{favorable / len(combos):.4f}")
